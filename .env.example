# Copy to .env and fill in, then: docker compose up -d --build
# Full walkthrough in README.md ("Deploy").

# ---- Domain -----------------------------------------------------------------
# Point a DNS A record at the VPS first. Caddy provisions the TLS certificate
# automatically on the first HTTPS request.
SITE_ADDRESS=board.example.com

# ---- Y-Sweet auth -----------------------------------------------------------
# Generate ONE keypair:
#   docker run --rm ghcr.io/jamsocket/y-sweet:latest gen-auth --json
#
#   private_key  -> Y_SWEET_AUTH (the sync server verifies client tokens with it)
#   server_token -> goes inside YSWEET_CONNECTION_STRING below
#
# The connection string is the ROOT credential for the sync server. It stays
# between the api and ysweet containers and must never reach a browser - the
# api mints short-scoped per-board client tokens from it (POST /api/token).
Y_SWEET_AUTH=REPLACE_WITH_private_key
YSWEET_CONNECTION_STRING=ys://REPLACE_WITH_server_token@ysweet:8080

# ---- S3-compatible storage ----------------------------------------------------
# One bucket for both Y-Sweet document persistence (under /ysweet) and
# uploaded images (under /assets). Any S3-compatible provider works.
S3_BUCKET=my-mathboard-bucket
Y_SWEET_STORE=s3://my-mathboard-bucket/ysweet
S3_ASSET_PREFIX=assets/
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_REGION=us-east-1
# AWS itself: https://s3.<region>.amazonaws.com - other providers: see their docs.
AWS_ENDPOINT_URL_S3=https://s3.us-east-1.amazonaws.com
# false on AWS; true for MinIO and most other S3-compatible providers.
AWS_S3_USE_PATH_STYLE=false
