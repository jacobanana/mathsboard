# Build the static frontend, then serve it (plus TLS + routing) with Caddy.
# The Caddyfile is bind-mounted by docker-compose so routing edits don't
# require an image rebuild.

FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY tsconfig.json tsconfig.node.json vite.config.ts index.html ./
# The About page (burger menu) imports this repo-root doc verbatim via Vite's
# `?raw` (src/ui/About.tsx), so it must be in the build context. Copied before
# src so edits to src/ don't bust this layer.
COPY ABOUT.md ./
COPY src ./src
# Passed by publish.yml (see .github/actions/app-version); Vite bakes any VITE_*
# env var into the bundle. Placed just before the build so the npm ci layer
# above stays cached when only the version changes.
ARG APP_VERSION=dev
ENV VITE_APP_VERSION=$APP_VERSION
# Umami analytics (optional). Umami runs on its own subdomain, so the tracker URL
# is an absolute, deployment-specific value - both it and the website id are
# passed as build-args by publish.yml from repo variables. Empty by default ->
# src/analytics.ts requires both, so nothing loads unless they're set.
ARG UMAMI_SRC=
ARG UMAMI_WEBSITE_ID=
ENV VITE_UMAMI_SRC=$UMAMI_SRC
ENV VITE_UMAMI_WEBSITE_ID=$UMAMI_WEBSITE_ID
RUN npm run build

FROM caddy:2-alpine
COPY --from=build /app/dist /srv
