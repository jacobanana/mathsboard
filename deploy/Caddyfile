# One domain, three routes, all same-origin (so no CORS anywhere and the
# websocket rides the same TLS cert):
#
#   /api/*  -> the token/upload service
#   /ys/*   -> the Y-Sweet sync server (websocket; prefix stripped - the
#              container serves at root, and the token endpoint rewrites the
#              URLs inside minted tokens to point here)
#   rest    -> the static frontend build
#
# SITE_ADDRESS comes from the environment:
#   production      SITE_ADDRESS=board.example.com   (automatic HTTPS via ACME;
#                   the FIRST request after DNS is live provisions the cert)
#   local testing   SITE_ADDRESS=:8080               (plain HTTP on port 8080)

{$SITE_ADDRESS}

encode zstd gzip

handle /api/* {
	reverse_proxy api:8787
}

handle_path /ys/* {
	reverse_proxy ysweet:8080
}

# Self-hosted Umami analytics, same-origin (the tracker at /umami/script.js is
# first-party, so ad-blockers don't drop it). Umami runs with BASE_PATH=/umami,
# so the prefix is passed through unstripped. Only present when the stack runs
# with the `analytics` profile; Caddy resolves the upstream lazily, so this is
# harmless when umami isn't running.
#
# Match BOTH the bare /umami and /umami/* — a `/umami/*` matcher alone does NOT
# match the slash-less entry URL, so it would fall through to the SPA catch-all.
@umami path /umami /umami/*
handle @umami {
	reverse_proxy umami:3000
}

handle {
	root * /srv
	try_files {path} /index.html
	file_server
}
