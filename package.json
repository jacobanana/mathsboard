{
  "name": "mathsboard",
  "private": true,
  "version": "0.0.0",
  "description": "An infinite-canvas maths whiteboard for teaching and learning maths together: written-method scaffolds with live answer-reveal, a toolbox of maths widgets, and real-time collaboration.",
  "license": "AGPL-3.0-only",
  "author": "Adrien Fauconnet",
  "homepage": "https://mathboard.mixedmode.ch",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacobanana/mathboard.git"
  },
  "bugs": "https://github.com/jacobanana/mathboard/issues",
  "keywords": [
    "maths",
    "math",
    "whiteboard",
    "education",
    "tutoring",
    "collaboration",
    "yjs",
    "canvas"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "preview": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@y-sweet/client": "^0.9.1",
    "katex": "^0.16.38",
    "mathlive": "^0.110.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "yjs": "^13.6.31",
    "zustand": "4.5.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "18.3.27",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "jsdom": "^29.1.1",
    "typescript": "5.9.3",
    "vite": "5.4.21",
    "vitest": "^3.2.6"
  }
}
